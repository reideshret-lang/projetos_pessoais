-- opcional

-- uma maneira de automatizar o banco de dados.

-- ele soma o preço da arma e da municao, depois adiciona o item no inventario do personagem, debita o dinheiro na saldo do personagem,
-- e coloca o valor no saldo do vendedor.

-- aviso importante: esse sistema apenas acumula e não remove o peso na coluna inventario_peso em comprador
-- caso queira excluir um item do inventario, lembre-se de remover o respectivo peso na coluna inventario_peso 

-- nessa automatizacao, é considerado que voce compra a municao e a arma juntos caso a arma precise de muniçao 

CREATE OR REPLACE FUNCTION trg_set_preco_vendido()
RETURNS TRIGGER AS $$
DECLARE
    v_preco_arma DECIMAL(10,2);
    v_preco_municao DECIMAL(10,2);
BEGIN

    SELECT preco_base
    INTO v_preco_arma
    FROM arma
    WHERE idarmas = NEW.idarmas;

    SELECT COALESCE(SUM(m.preco), 0)
    INTO v_preco_municao
    FROM arma_municao am
    JOIN municoes m ON m.idmunicoes = am.idmunicoes
    WHERE am.idarmas = NEW.idarmas;

    NEW.preco_unitario := v_preco_arma + v_preco_municao;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_set_preco_vendido
BEFORE INSERT ON vendidos
FOR EACH ROW
EXECUTE FUNCTION trg_set_preco_vendido();

CREATE OR REPLACE FUNCTION trg_pos_venda_fn()
RETURNS TRIGGER AS $$
DECLARE
    v_idcomprador INT;
    v_idvendedor INT;
    v_peso DECIMAL(10,2);
    v_total DECIMAL(10,2);
BEGIN

    SELECT idcomprador, idvendedores
    INTO v_idcomprador, v_idvendedor
    FROM vendas
    WHERE idvendas = NEW.idvendas;

    v_total := NEW.preco_unitario * NEW.quantidade;

    SELECT peso
    INTO v_peso
    FROM arma
    WHERE idarmas = NEW.idarmas;

    IF (SELECT moedas FROM comprador WHERE idcomprador = v_idcomprador) < v_total THEN
        RAISE EXCEPTION 'Moedas insuficientes';
    END IF;

    INSERT INTO inventario (idarmas, idcomprador, quantidade)
    VALUES (NEW.idarmas, v_idcomprador, NEW.quantidade)
    ON CONFLICT (idarmas, idcomprador)
    DO UPDATE SET
        quantidade = inventario.quantidade + EXCLUDED.quantidade;

    UPDATE comprador
    SET moedas = moedas - v_total,
        inventario_peso = inventario_peso + (v_peso * NEW.quantidade)
    WHERE idcomprador = v_idcomprador;

    UPDATE vendedores
    SET moedas = moedas + v_total
    WHERE idvendedores = v_idvendedor;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_pos_venda
AFTER INSERT ON vendidos
FOR EACH ROW
EXECUTE FUNCTION trg_pos_venda_fn();
